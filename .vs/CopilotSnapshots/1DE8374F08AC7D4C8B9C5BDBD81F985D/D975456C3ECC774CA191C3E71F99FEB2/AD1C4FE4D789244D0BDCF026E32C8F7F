<Window x:Class="QuanLiTrongTrot.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLiTrongTrot"
        mc:Ignorable="d"
        Title="Quản lý Trồng Trọt - Đăng nhập" 
        Height="550" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    
    <Grid>
        <!-- Background Image -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/login_background.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
        
        <!-- Fallback gradient background if image not found -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E8F5E9" Offset="0"/>
                    <GradientStop Color="#C8E6C9" Offset="0.5"/>
                    <GradientStop Color="#A5D6A7" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        
        <!-- Close Button -->
        <Button x:Name="btnClose" 
                Content="✕" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top"
                Margin="0,10,15,0"
                Width="30" Height="30"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#555555"
                FontSize="16"
                Cursor="Hand"
                Click="btnClose_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#33000000"/>
                                        <Setter Property="Foreground" Value="#FF0000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
        
        <!-- Login Card -->
        <Border HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Width="380" 
                Height="380"
                CornerRadius="20"
                Padding="40,30">
            <Border.Background>
                <SolidColorBrush Color="White" Opacity="0.85"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" 
                                  ShadowDepth="0" 
                                  Color="#000000" 
                                  Opacity="0.15"/>
            </Border.Effect>
            
            <StackPanel VerticalAlignment="Center">
                <!-- Title -->
                <TextBlock Text="Quản lý Trồng Trọt"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#2E7D32"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,35"
                           FontFamily="Segoe UI"/>
                
                <!-- Username Field -->
                <Border Background="White" 
                        CornerRadius="25" 
                        Height="50"
                        Margin="0,0,0,15"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" 
                                          ShadowDepth="1" 
                                          Color="#000000" 
                                          Opacity="0.08"/>
                    </Border.Effect>
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Leaf Icon -->
                        <Path Grid.Column="0" 
                              Data="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"
                              Fill="#4CAF50"
                              Stretch="Uniform"
                              Width="20" Height="20"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                        
                        <TextBox x:Name="txtUsername"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 FontSize="14"
                                 Foreground="#333333"/>
                        
                        <!-- Placeholder -->
                        <TextBlock Grid.Column="1"
                                   Text="Tên đăng nhập"
                                   VerticalAlignment="Center"
                                   Foreground="#9E9E9E"
                                   FontSize="14"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtUsername}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                
                <!-- Password Field -->
                <Border Background="White" 
                        CornerRadius="25" 
                        Height="50"
                        Margin="0,0,0,25"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" 
                                          ShadowDepth="1" 
                                          Color="#000000" 
                                          Opacity="0.08"/>
                    </Border.Effect>
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Leaf Icon -->
                        <Path Grid.Column="0" 
                              Data="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z"
                              Fill="#4CAF50"
                              Stretch="Uniform"
                              Width="20" Height="20"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                        
                        <PasswordBox x:Name="txtPassword"
                                     Grid.Column="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalAlignment="Center"
                                     FontSize="14"
                                     PasswordChanged="txtPassword_PasswordChanged"/>
                        
                        <!-- Placeholder for Password -->
                        <TextBlock x:Name="txtPasswordPlaceholder"
                                   Grid.Column="1"
                                   Text="Mật khẩu"
                                   VerticalAlignment="Center"
                                   Foreground="#9E9E9E"
                                   FontSize="14"
                                   IsHitTestVisible="False"/>
                        
                        <!-- Show/Hide Password Button -->
                        <Button x:Name="btnShowPassword"
                                Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnShowPassword_Click"
                                Width="25" Height="25">
                            <Path x:Name="eyeIcon"
                                  Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                  Fill="#9E9E9E"
                                  Stretch="Uniform"
                                  Width="18" Height="18"/>
                        </Button>
                    </Grid>
                </Border>
                
                <!-- Login Button -->
                <Button x:Name="btnLogin"
                        Content="Đăng nhập"
                        Height="50"
                        Margin="0,0,0,20"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Cursor="Hand"
                        Click="btnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" 
                                                CornerRadius="25"
                                                Background="#2E7D32">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" 
                                                                  ShadowDepth="2" 
                                                                  Color="#2E7D32" 
                                                                  Opacity="0.4"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#1B5E20"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#145214"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Forgot Password Link -->
                <TextBlock Text="Quên mật khẩu?"
                           HorizontalAlignment="Center"
                           Foreground="#666666"
                           FontSize="13"
                           Cursor="Hand"
                           MouseLeftButtonDown="ForgotPassword_Click">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
